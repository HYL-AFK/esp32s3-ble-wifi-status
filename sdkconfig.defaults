# Default mode keeps the existing Wi-Fi + BLE provisioning flow.
# Enable Mesh Audio Control from menuconfig when building gateway/controller/speaker firmware.
# CONFIG_MESH_AUDIO_ENABLE is not set

CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y
# CONFIG_BT_NIMBLE_MESH is not set
CONFIG_LWIP_SNTP_MAX_SERVERS=2

# ESP32-S3FH4R2: 4MB Flash + 2MB PSRAM
# 当前工程已经接入 BLE/Wi-Fi/LVGL/HTTP，默认单 app 小分区已不够用。
# 这里直接切到 4MB flash，并使用 large single app 分区表。
# CONFIG_ESPTOOLPY_FLASHSIZE_2MB is not set
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="4MB"
# CONFIG_PARTITION_TABLE_SINGLE_APP is not set
# CONFIG_PARTITION_TABLE_SINGLE_APP_LARGE is not set
CONFIG_PARTITION_TABLE_TWO_OTA=y
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_FILENAME="partitions.csv"
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE=y

# ST7789 SPI display bring-up defaults.
CONFIG_DISPLAY_ST7789_ENABLE=y
CONFIG_DISPLAY_ST7789_H_RES=240
CONFIG_DISPLAY_ST7789_V_RES=320
CONFIG_DISPLAY_ST7789_PIXEL_CLOCK_HZ=60000000
CONFIG_DISPLAY_ST7789_SCLK_GPIO=12
CONFIG_DISPLAY_ST7789_MOSI_GPIO=11
CONFIG_DISPLAY_ST7789_MISO_GPIO=10
CONFIG_DISPLAY_ST7789_CS_GPIO=8
CONFIG_DISPLAY_ST7789_DC_GPIO=9
CONFIG_DISPLAY_ST7789_RST_GPIO=13
CONFIG_DISPLAY_ST7789_BL_GPIO=-1
CONFIG_DISPLAY_ST7789_BL_ON_LEVEL=1
CONFIG_DISPLAY_ST7789_BL_OFF_LEVEL=0
CONFIG_DISPLAY_ST7789_INVERT_COLOR=y
# CONFIG_DISPLAY_ST7789_BGR is not set
# CONFIG_DISPLAY_ST7789_SWAP_XY is not set
# CONFIG_DISPLAY_ST7789_MIRROR_X is not set
# CONFIG_DISPLAY_ST7789_MIRROR_Y is not set
CONFIG_DISPLAY_ST7789_X_GAP=0
CONFIG_DISPLAY_ST7789_Y_GAP=0
CONFIG_FONT_GB2312_ENABLE=y
CONFIG_FONT_GB2312_CSF_GPIO=7
CONFIG_FONT_GB2312_SPI_CLOCK_HZ=10000000
CONFIG_FONT_GB2312_DEFAULT_SIZE_16=y
CONFIG_FONT_GB2312_DEFAULT_SIZE=16
CONFIG_FONT_GB2312_BASE_12=0x000000
CONFIG_FONT_GB2312_BASE_14=0x02FEF0
CONFIG_FONT_GB2312_BASE_16=0x067D68
CONFIG_FONT_GB2312_BASE_18=0x0A7BA8
CONFIG_FONT_GB2312_BASE_20=0x1137B4
CONFIG_FONT_GB2312_BASE_22=0x18B5A4
CONFIG_FONT_GB2312_BASE_24=0x20F43C
CONFIG_FONT_GB2312_BASE_26=0x2BD054
